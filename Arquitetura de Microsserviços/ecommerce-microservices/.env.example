# ===========================================
# E-COMMERCE MICROSERVICES - ENVIRONMENT TEMPLATE
# Copy to .env and fill with real values. NEVER commit .env
# ===========================================

# Database (per-service override in each service .env)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=default-group

# JWT (User Service / API Gateway)
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Observability
JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=ecommerce
OTEL_EXPORTER_OTLP_ENDPOINT=

# Stripe (Payment Service)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Notification Service)
SENDGRID_API_KEY=SG....
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Elasticsearch (Search Service)
ELASTICSEARCH_NODE=http://localhost:9200

# API Gateway
GATEWAY_PORT=8080
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
